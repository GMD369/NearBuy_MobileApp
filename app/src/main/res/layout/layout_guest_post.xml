<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF">

    <ImageView
        android:id="@+id/ivGuestPostIcon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_nav_post"
        android:alpha="0.12"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/tvGuestPostTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvGuestPostTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign in to Post"
        android:textSize="22sp"
        android:textColor="#0D0D0D"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02"
        app:layout_constraintBottom_toTopOf="@id/tvGuestPostDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvGuestPostDesc"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:text="To post a new listing you need to be logged in to your account."
        android:textSize="14sp"
        android:textColor="#888888"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.5"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/btnGuestPostLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuestPostLogin"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="Login / Register"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        app:backgroundTint="#FF6600"
        app:cornerRadius="14dp"
        app:elevation="0dp"
        app:rippleColor="#22000000"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnGuestPostHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuestPostHome"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="Go to Home"
        android:textSize="15sp"
        android:textColor="#FF6600"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        app:strokeColor="#FF6600"
        app:strokeWidth="1.5dp"
        app:cornerRadius="14dp"
        app:rippleColor="#11FF6600"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp" />

    <!-- centered vertically as a group via chain -->
    <androidx.constraintlayout.widget.Group
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="ivGuestPostIcon,tvGuestPostTitle,tvGuestPostDesc,btnGuestPostLogin,btnGuestPostHome" />

</androidx.constraintlayout.widget.ConstraintLayout>
