<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivRestrictionIllustration"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/ic_nav_post"
        android:alpha="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvRestrictionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvRestrictionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Action Required"
        android:textSize="24sp"
        android:textColor="#0D0D0D"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivRestrictionIllustration"
        app:layout_constraintBottom_toTopOf="@id/tvRestrictionDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRestrictionDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To ensure a safe marketplace, we require sellers to complete their profile before posting items."
        android:textSize="15sp"
        android:textColor="#666666"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvRestrictionTitle"
        app:layout_constraintBottom_toTopOf="@id/layoutChecklist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutChecklist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_checklist_card"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvRestrictionDesc"
        app:layout_constraintBottom_toTopOf="@id/btnAction">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Missing Requirements:"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvCheckPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Phone Number"
            android:textSize="14sp"
            android:textColor="#FF6600"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCheckLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Location"
            android:textSize="14sp"
            android:textColor="#FF6600"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCheckPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Profile Photo"
            android:textSize="14sp"
            android:textColor="#FF6600"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAction"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Complete Profile"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="32dp"
        app:backgroundTint="#FF6600"
        app:cornerRadius="16dp"
        app:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/layoutChecklist"
        app:layout_constraintBottom_toTopOf="@id/btnSecondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSecondary"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Go Back"
        android:textSize="15sp"
        android:textColor="#888888"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnAction"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
