<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help &amp; FAQ"
            android:textSize="24sp"
            android:textColor="#0D0D0D"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="24dp" />

        <!-- FAQ Item 1 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EEEEEE">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How do I post a listing?"
                    android:textSize="16sp"
                    android:textColor="#0D0D0D"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Go to the 'Post' tab in the bottom navigation. If your profile is complete, you can follow the steps to add images, title, category, and description for your item."
                    android:textSize="14sp"
                    android:textColor="#666666" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ Item 2 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EEEEEE">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What is the Swap feature?"
                    android:textSize="16sp"
                    android:textColor="#0D0D0D"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="The Swap feature allows you to propose an exchange of items with another user instead of buying with money. You can find the Swap option on listing details."
                    android:textSize="14sp"
                    android:textColor="#666666" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ Item 3 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EEEEEE">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Is my data safe?"
                    android:textSize="16sp"
                    android:textColor="#0D0D0D"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="NearBuy takes user privacy seriously. Your contact information is only shared with users you choose to interact with for swaps or purchases."
                    android:textSize="14sp"
                    android:textColor="#666666" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ Item 4 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EEEEEE">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How do I complete my profile?"
                    android:textSize="16sp"
                    android:textColor="#0D0D0D"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="To complete your profile, go to the Profile tab, open the menu (filter icon), and select 'Edit Profile'. Ensure you provide a name, phone number, location, and profile photo."
                    android:textSize="14sp"
                    android:textColor="#666666" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Need more help?"
            android:textSize="16sp"
            android:textColor="#0D0D0D"
            android:fontFamily="sans-serif-bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact us at support@nearbuy.com"
            android:textSize="14sp"
            android:textColor="#FF6600"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
