<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF">

    <ImageView
        android:id="@+id/ivGuestSwapIcon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_nav_swap"
        android:alpha="0.12"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/tvGuestSwapTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvGuestSwapTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign in to Swap"
        android:textSize="22sp"
        android:textColor="#0D0D0D"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/tvGuestSwapDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvGuestSwapDesc"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:text="To view and manage your swap proposals you need to be logged in."
        android:textSize="14sp"
        android:textColor="#888888"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.5"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@id/btnGuestSwapLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuestSwapLogin"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="Login / Register"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        app:backgroundTint="#FF6600"
        app:cornerRadius="14dp"
        app:elevation="0dp"
        app:rippleColor="#22000000"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnGuestSwapHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuestSwapHome"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="Go to Home"
        android:textSize="15sp"
        android:textColor="#FF6600"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        app:strokeColor="#FF6600"
        app:strokeWidth="1.5dp"
        app:cornerRadius="14dp"
        app:rippleColor="#11FF6600"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
