<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp">

        <!-- Top accent bar -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#FF6600"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Warm top background -->
        <View
            android:id="@+id/topBg"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#FFF5EE"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Brand name split color -->
        <LinearLayout
            android:id="@+id/layoutBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="52dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Near"
                android:textSize="32sp"
                android:textColor="#FF6600"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buy"
                android:textSize="32sp"
                android:textColor="#555555"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvLoginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="8dp"
            android:text="Welcome Back"
            android:textSize="26sp"
            android:textColor="#0D0D0D"
            android:fontFamily="sans-serif-black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutBrand" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvLoginSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="6dp"
            android:text="Login to your NearBuy account"
            android:textSize="14sp"
            android:textColor="#999999"
            android:fontFamily="sans-serif"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLoginTitle" />

        <!-- Content card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/contentCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="96dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvLoginSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="32dp">

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email Address"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#DDDDDD"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#FF6600"
                    app:startIconDrawable="@drawable/ic_field_email"
                    app:startIconTint="#FF6600"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textSize="15sp"
                        android:textColor="#0D0D0D"
                        android:fontFamily="sans-serif" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Password"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="#DDDDDD"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#FF6600"
                    app:passwordToggleEnabled="true"
                    app:startIconDrawable="@drawable/ic_field_lock"
                    app:startIconTint="#FF6600"
                    app:layout_constraintTop_toBottomOf="@id/tilEmail"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textSize="15sp"
                        android:textColor="#0D0D0D"
                        android:fontFamily="sans-serif" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Remember me -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchRemember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Remember me"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:fontFamily="sans-serif"
                    app:thumbTint="#FF6600"
                    app:trackTint="#FFCCAA"
                    app:layout_constraintTop_toBottomOf="@id/tilPassword"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Login button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="28dp"
                    android:text="Login"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    app:backgroundTint="#FF6600"
                    app:cornerRadius="14dp"
                    app:elevation="0dp"
                    app:rippleColor="#22000000"
                    app:layout_constraintTop_toBottomOf="@id/switchRemember"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Guest button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSkipLogin"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Continue as Guest"
                    android:textSize="14sp"
                    android:textColor="#FF6600"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    app:strokeColor="#FF6600"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="14dp"
                    app:rippleColor="#11FF6600"
                    app:layout_constraintTop_toBottomOf="@id/btnLogin"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Register link -->
        <TextView
            android:id="@+id/btnGoToRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            android:text="Don't have an account? Register"
            android:textSize="13sp"
            android:textColor="#FF6600"
            android:fontFamily="sans-serif-medium"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/contentCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>