<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price &amp; Options"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvPriceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price: Rs. 1,000"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <com.google.android.material.slider.Slider
        android:id="@+id/priceSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0"
        android:valueTo="500000"
        android:stepSize="500"
        android:value="1000"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchSwap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open to Swap"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        app:useMaterialThemeColors="true" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="If enabled, other users can propose items for trade instead of cash."
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:alpha="0.7"
        android:layout_marginTop="8dp"/>

</LinearLayout>