<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit"
            android:textSize="28sp"
            android:textColor="#0D0D0D"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="28sp"
            android:textColor="#FF6600"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="28dp" />

        <!-- Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_avatar_ring" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivEditProfileImage"
                    android:layout_width="94dp"
                    android:layout_height="94dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                <!-- Camera badge -->
                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_camera_badge">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        app:tint="#FFFFFF" />

                </FrameLayout>

            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangePhoto"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Change Photo"
                android:textSize="13sp"
                android:textColor="#FF6600"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                app:rippleColor="#11FF6600" />

        </LinearLayout>

        <!-- Full Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEditName"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Full Name"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#FF6600"
            app:startIconDrawable="@drawable/ic_field_email"
            app:startIconTint="#FF6600"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEditName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textSize="15sp"
                android:textColor="#0D0D0D"
                android:fontFamily="sans-serif" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEditPhone"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Phone Number"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#FF6600"
            app:startIconDrawable="@drawable/ic_field_lock"
            app:startIconTint="#FF6600">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEditPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textSize="15sp"
                android:textColor="#0D0D0D"
                android:fontFamily="sans-serif" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Province Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEditProvince"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Province"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#FF6600"
            app:startIconDrawable="@drawable/ic_location_pin"
            app:startIconTint="#FF6600">

            <AutoCompleteTextView
                android:id="@+id/acEditProvince"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="15sp"
                android:textColor="#0D0D0D"
                android:fontFamily="sans-serif" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- City Dropdown (Dependent on Province) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEditLocation"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="City"
            android:enabled="false"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#FF6600"
            app:startIconDrawable="@drawable/ic_location_pin"
            app:startIconTint="#FF6600">

            <AutoCompleteTextView
                android:id="@+id/acEditLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="15sp"
                android:textColor="#0D0D0D"
                android:fontFamily="sans-serif" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bio -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEditBio"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Bio"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#FF6600"
            app:counterEnabled="true"
            app:counterMaxLength="120">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEditBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textSize="15sp"
                android:textColor="#0D0D0D"
                android:fontFamily="sans-serif" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Changes"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02"
            android:layout_marginBottom="16dp"
            app:backgroundTint="#FF6600"
            app:cornerRadius="14dp"
            app:elevation="0dp"
            app:rippleColor="#22000000" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>