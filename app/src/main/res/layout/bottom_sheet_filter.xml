<?xml version="1.0" encoding="utf-8"?>
<!--
    Wire up in HomeFragment:
        binding.btnFilter.setOnClickListener {
            FilterBottomSheetFragment().show(childFragmentManager, "filter")
        }
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filters"
            android:textSize="20sp"
            android:textColor="#0D0D0D"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/tvResetFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:textSize="13sp"
            android:textColor="#FF6600"
            android:fontFamily="sans-serif-medium"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Price range label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price Range"
        android:textSize="14sp"
        android:textColor="#0D0D0D"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="6dp" />

    <!-- Min / Max price inputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMinPrice"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:hint="Min (Rs.)"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#FF6600">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMinPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:textColor="#0D0D0D"
                android:fontFamily="sans-serif" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMaxPrice"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="Max (Rs.)"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:boxStrokeWidth="1.5dp"
            app:hintTextColor="#FF6600">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMaxPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:textColor="#0D0D0D"
                android:fontFamily="sans-serif" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Category label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textSize="14sp"
        android:textColor="#0D0D0D"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="10dp" />

    <!-- Category chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:singleSelection="true"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="6dp" />

    <!-- Sort by label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort By"
        android:textSize="14sp"
        android:textColor="#0D0D0D"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="10dp" />

    <!-- Sort chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="6dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipNewest"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Newest"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:checked="true"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="#DDDDDD"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPriceLow"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price: Low→High"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="#DDDDDD"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPriceHigh"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price: High→Low"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="#DDDDDD"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipNearest"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nearest"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="#DDDDDD"
            app:chipStrokeWidth="1dp" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Condition label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Condition"
        android:textSize="14sp"
        android:textColor="#0D0D0D"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="10dp" />

    <!-- Condition chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupCondition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:singleSelection="false"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="6dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipNew"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="#DDDDDD"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipUsed"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Used"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="#DDDDDD"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipRefurbished"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refurbished"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="#DDDDDD"
            app:chipStrokeWidth="1dp" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Apply button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyFilters"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Apply Filters"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.02"
        app:backgroundTint="#FF6600"
        app:cornerRadius="14dp"
        app:elevation="0dp"
        app:rippleColor="#22000000" />

</LinearLayout>